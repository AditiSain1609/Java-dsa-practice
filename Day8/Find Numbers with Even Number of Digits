class Solution {
    public int findNumbers(int[] nums) {
        int count =0;
        int num=0;
        for(int i=0;i<nums.length;i++){
            int n=nums[i];
            
            if(n==0){
                num=0;
            }
            while(n!=0){
                n=n/10;
                count ++;
            }
        
            if(count%2==0){
                num++;
            }
            count =0;

        }
        return num;
    }
}
